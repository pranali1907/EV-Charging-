FLASK_ENV=development
SECRET_KEY=replace-with-a-secure-secret-key
PORT=5000
# Optional: Combined PostgreSQL URL (Takes precedence over separate variables)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/chargelive_db

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=chargelive_db
DATABASE_USER=postgres
DATABASE_PASSWORD=replace-with-postgres-password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-generated-password-hash
